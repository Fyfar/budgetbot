<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Telegram long-polling fires SocketTimeoutException every ~50s when idle — this is expected reconnect behaviour, not an error -->
    <logger name="org.telegram.telegrambots.updatesreceivers.DefaultBotSession" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
